{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  },
  "Serilog": {
    "Using": [ "Serilog.Sinks.File", "Serilog.Sinks.Console" ],
    "MinimumLevel": "Information",
    "Override": {
    "Microsoft": "Warning",
    "Microsoft.Hosting.Lifetime": "Information"
    },
    "WriteTo": [{
      "Name": "Console"
      }, 
      {
        "Name": "File",
        "Args": {
          "path": "C:\\Signer\\Logs\\log.log",
          "rollingInterval": "Day",
          "rollOnFileSizeLimit": true
        }
      }
    ],
    "Properties": {
      "Application": "Signer"
    }
  },
  "CryptoSettings" : {
    "SerialNumber" : "",
    "SubjectName" : "Kirill Safonov"
  },
  "FileSettings" : {
    "DocumentFolder" : "C:\\Signer\\Documents",
    "DocumentExtension" : "pdf",
    "SignFolder" : "C:\\Signer\\Signs",
    "SignExtension" : "sig"
  },
  "WorkerSettings" : {
    "Delay" : 10000
  }
}
